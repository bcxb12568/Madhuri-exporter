{
  "entities": {
    "inquiry": {
      "title": "Customer Inquiry",
      "description": "Contact form submissions from visitors",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["new", "reviewed", "contacted"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "subject", "message", "status", "createdAt"]
    },
    "siteSettings": {
      "title": "Site Settings",
      "description": "Global configuration for the website",
      "type": "object",
      "properties": {
        "heroTitle": { "type": "string" },
        "heroSubtitle": { "type": "string" },
        "contactEmail": { "type": "string" },
        "contactPhone": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "branch": {
      "title": "Hotel Branch",
      "description": "Information about a specific hotel location",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "address": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "image", "description", "updatedAt"]
    },
    "room": {
      "title": "Room Type",
      "description": "Details about a room category",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "size": { "type": "string" },
        "description": { "type": "string" },
        "features": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "image", "size", "description", "features", "updatedAt"]
    }
  },
  "firestore": {
    "inquiries/{inquiryId}": {
      "schema": "inquiry",
      "description": "Collection of all customer inquiries"
    },
    "settings/website": {
      "schema": "siteSettings",
      "description": "Singleton document for website configuration"
    },
    "branches/{branchId}": {
      "schema": "branch",
      "description": "Manage hotel locations"
    },
    "rooms/{roomId}": {
      "schema": "room",
      "description": "Manage room categories"
    }
  }
}

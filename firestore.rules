rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Logic for Inquiries
    function isValidInquiry(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email', 'subject', 'message', 'status', 'createdAt'])
        && data.firstName is string && data.firstName.size() <= 100
        && data.lastName is string && data.lastName.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.subject is string && data.subject.size() <= 200
        && data.message is string && data.message.size() <= 2000
        && data.status in ['new', 'reviewed', 'contacted']
        && data.createdAt == request.time;
    }

    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(incoming());
      allow read: if isAdmin();
      allow update: if isAdmin() && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    // Logic for Website Settings
    match /settings/{settingId} {
      allow read: if true; // Publicly readable for site config
      allow write: if isAdmin();
    }

    // Logic for Branches & Rooms
    match /branches/{branchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rooms/{roomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Access Collection (Managed manually or via bootstrapper)
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
